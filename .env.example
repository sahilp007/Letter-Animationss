# Telemetry destinations (set in Vercel project env vars, not committed)
# Telegram (recommended — instant push to your phone):
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OR Discord webhook (alternative):
DISCORD_WEBHOOK_URL=

# Lock the telemetry endpoint to your deployed origin (e.g. https://heartbeat.example.com)
ALLOWED_ORIGIN=

# Optional: Vercel KV / Upstash for an audit trail of every event
KV_REST_API_URL=
KV_REST_API_TOKEN=
